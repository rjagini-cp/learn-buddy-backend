# Required environment variables for Railway deployment

# MongoDB connection string (from MongoDB Atlas or Railway MongoDB plugin)
# Example Atlas format: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=

# Logical DB name (any name; will be auto-created on first write)
DB_NAME=your_learning_buddy

# Emergent LLM key (powers Gemini curriculum question generation)
# Get from Emergent profile -> Universal Key
EMERGENT_LLM_KEY=
